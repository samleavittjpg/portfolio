# Copy this file to .env (never commit .env).
#
# Local MongoDB:
#   MONGODB_URI=mongodb://127.0.0.1:27017/portfolio
#
# MongoDB Atlas:
#   Atlas → Database → Connect → Drivers → copy the SRV string.
#   Replace <password> with your DB user password (URL-encode special chars).
#   Atlas → Network Access → allow your current IP, or 0.0.0.0/0 for quick dev only.
#   Example shape:
#   MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio
PORT=4000
SESSION_SECRET=replace-with-long-random-string
AUTH_USERNAME=1337
AUTH_PASSWORD=password

# Split deploy (Vercel frontend): comma-separated origins, no spaces
# Example: https://your-app.vercel.app,https://your-preview.vercel.app
# CORS_ORIGINS=
